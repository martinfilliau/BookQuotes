<MudGrid>
    <MudItem xs="12">
        <MudStack Row="true" Spacing="6">
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadFiles"
                           Accept=".epub,.xml,.annot" AppendMultipleFiles="false">
                <CustomContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="@context.OpenFilePickerAsync"
                               StartIcon="@Icons.Material.Filled.CloudUpload">
                        Upload Epub or XML files with annotations
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                       Disabled="Books.Count == 0"
                       OnClick="Reset">Reset</MudButton>
        </MudStack>
    </MudItem>
    <MudItem xs="12">
        <MudStack Spacing="4">
        @foreach (var book in Books)
        {
            var epubStream = EpubStreams.TryGetValue(book.Title, out var stream) ? stream : null;
            <BookComponent Book="@book" EpubStream="@epubStream"></BookComponent>
        }
        </MudStack>
    </MudItem>
</MudGrid>
