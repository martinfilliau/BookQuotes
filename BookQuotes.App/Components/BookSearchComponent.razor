@if (IsIndexed)
{
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Search in book content</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudTextField @bind-Value="SearchQuery"
                          Label="Search"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnAdornmentClick="PerformSearch"
                          OnKeyUp="HandleKeyUp"
                          Immediate="false"/>

            @if (IsSearching)
            {
                <MudProgressLinear Indeterminate="true" Class="my-2"/>
            }

            @if (SearchResults.Any())
            {
                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">
                    Found @SearchResults.Count result(s)
                </MudText>

                <MudStack Spacing="2">
                    @for (var i = 0; i < SearchResults.Count; i++)
                    {
                        var index = i;
                        var result = SearchResults[index];
                        var isExpanded = ExpandedResults.Contains(index);

                        <MudPaper Elevation="1" Class="pa-4" Style="cursor: pointer;" @onclick="() => ToggleExpand(index)">
                            <MudText Typo="Typo.body1">
                                @((MarkupString)(isExpanded ? result.ExpandedContent : result.HighlightedContent))
                            </MudText>
                            <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.caption">
                                    Location: @(result.FileTitle ?? result.FileUrl)
                                </MudText>
                                <MudSpacer />
                                <MudText Typo="Typo.caption">
                                    Score: @result.Score.ToString("F2")
                                </MudText>
                                <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
            else if (!string.IsNullOrWhiteSpace(SearchQuery) && !IsSearching && HasSearched)
            {
                <MudText Typo="Typo.body2" Class="mt-4">No results found.</MudText>
            }
        </MudCardContent>
    </MudCard>
}
